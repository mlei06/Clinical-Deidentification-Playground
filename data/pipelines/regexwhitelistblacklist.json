{
  "pipes": [
    {
      "type": "regex_ner",
      "config": {
        "source_name": "regex_ner",
        "skip_overlapping": false
      }
    },
    {
      "type": "whitelist",
      "config": {
        "source_name": "whitelist",
        "skip_overlapping": false,
        "labels": {
          "FIRST_NAME": {
            "enabled": true,
            "remap": null,
            "terms": [],
            "dictionaries": ["male-first-names", "female_first_names"]
          },
          "LAST_NAME": {
            "enabled": true,
            "remap": null,
            "terms": [],
            "dictionaries": ["last_names"]
          },
          "HOSPITAL": {
            "enabled": true,
            "remap": null,
            "terms": [],
            "dictionaries": ["us_hospitals"]
          },
          "LOCATION": {
            "enabled": true,
            "remap": null,
            "terms": [],
            "dictionaries": ["us_cities", "local_places_unambig_v2", "LOCATION__us_states"]
          },
          "STATE": {
            "enabled": true,
            "remap": null,
            "terms": [],
            "dictionaries": ["STATE__us_states"]
          }
        }
      }
    },
    {
      "type": "blacklist",
      "config": {
        "dict_config": {
          "disabled_dictionaries": [
            "commonest_words",
            "common_words",
            "sno_edited"
          ]
        },
        "match": "any_token",
        "apply_to_labels": null,
        "load_all_dictionaries": true
      }
    }
  ],
  "description": "test pipeline"
}
