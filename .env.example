# Clinical De-Identification Playground — backend environment template
#
# Copy to ".env" in the repo root (gitignored) or set CLINICAL_DEID_ENV_FILE to an absolute path.
# Docker Compose: root ``compose.yaml`` loads this file into the API container when present
# (``env_file``, optional). Use it for production keys without editing the Compose file.
# Resolution order: CLINICAL_DEID_ENV_FILE → walk up from cwd for ".env" → ".env" next to pyproject.toml.
#
# Pydantic Settings: env_prefix CLINICAL_DEID_ for most fields. List-valued settings expect JSON arrays.
# API entry point: clinical-deid-api (single FastAPI app; see docs/deployment.md).

# =============================================================================
# Optional API authentication
# =============================================================================
# JSON arrays of secret strings. When BOTH lists are empty/unset, auth is OFF (local dev; /docs enabled).
# When either list is non-empty, clients must send Authorization: Bearer <key> or X-API-Key: <key>.
# Admin keys satisfy all routes; inference keys are limited (see docs/api.md and tests/test_auth_contract.py).
# OpenAPI /docs /redoc /openapi.json are disabled for anonymous users when auth is enabled.
#
# CLINICAL_DEID_ADMIN_API_KEYS=["change-me-admin"]
# CLINICAL_DEID_INFERENCE_API_KEYS=["change-me-inference"]

# =============================================================================
# CORS (browser SPAs: Playground :3000, production UI :3001, or remote origins)
# =============================================================================
# Default if unset: ["http://localhost:3000","http://127.0.0.1:3000"]
# CLINICAL_DEID_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001"]

# =============================================================================
# Request body size cap (bytes). Requests above this are rejected with 413 at the edge.
# =============================================================================
# Default: 10 MiB (10485760). File upload handlers apply their own stricter per-file caps.
# CLINICAL_DEID_MAX_BODY_BYTES=10485760

# =============================================================================
# Paths & storage (all optional; paths are relative to the process working directory unless absolute)
# =============================================================================
# All mutable state defaults to ./data/ so a deployment mounts one volume.
# Models are read-only at runtime and default to ./models/.
# CLINICAL_DEID_DATABASE_URL=sqlite:///./data/app.sqlite
# CLINICAL_DEID_PIPELINES_DIR=data/pipelines
# CLINICAL_DEID_MODES_PATH=data/modes.json
# CLINICAL_DEID_EVALUATIONS_DIR=data/evaluations
# CLINICAL_DEID_INFERENCE_RUNS_DIR=data/inference_runs
# CLINICAL_DEID_MODELS_DIR=models
# CLINICAL_DEID_DICTIONARIES_DIR=data/dictionaries
# Corpus root: each dataset is ``<CORPORA_DIR>/<name>/dataset.json`` plus ``corpus.jsonl`` or BRAT files.
# CLINICAL_DEID_CORPORA_DIR=data/corpora
# Deprecated alias for CORPORA_DIR (logs a warning):
# CLINICAL_DEID_PROCESSED_DIR=

# =============================================================================
# Deploy / modes (file on disk, not an env var)
# =============================================================================
# Mode aliases, allowlist, and production audit proxy URL live in data/modes.json
# (override with CLINICAL_DEID_MODES_PATH). Edited via GET/PUT /deploy and the
# Deploy tab; the file must be writable when operators save deploy changes.

# =============================================================================
# OpenAI-compatible API (LLM synthesis, dataset generation, llm_ner when configured)
# =============================================================================
# API key: either name works (no CLINICAL_DEID_ prefix on OPENAI_API_KEY).
OPENAI_API_KEY=
# CLINICAL_DEID_OPENAI_API_KEY=

# Base URL and model (optional; defaults in code match gpt-4o-mini @ api.openai.com).
# Aliases: CLINICAL_DEID_OPENAI_BASE_URL, CLINICAL_DEID_OPENAI_MODEL
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# NeuroNER HTTP sidecar (neuroner-cspmc/sidecar; neuroner_ner pipe default base URL)
# =============================================================================
# CLINICAL_DEID_NEURONER_HTTP_URL=http://127.0.0.1:8765
# NEURONER_HTTP_URL=http://127.0.0.1:8765
