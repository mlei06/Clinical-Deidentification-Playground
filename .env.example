# Copy to ".env" in the project root and fill in values. ".env" is gitignored.
# Optional: absolute path to this file (or another env file) if not at cwd / repo root:
# CLINICAL_DEID_ENV_FILE=/path/to/.env

# --- OpenAI (LLM note synthesis via clinical_deid.synthesis)
# Pydantic accepts either name; OPENAI_* matches common tooling.
OPENAI_API_KEY=
# CLINICAL_DEID_OPENAI_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- App / API (optional overrides; all use CLINICAL_DEID_ prefix)
# CLINICAL_DEID_DATABASE_URL=sqlite:///./var/dev.sqlite
# CLINICAL_DEID_LOCAL_DATA_DIR=var/data
