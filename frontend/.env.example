# Copy to `.env.local` (gitignored) and set values for your environment.
# https://vite.dev/guide/env-and-mode.html

# Backend origin for API calls. Default when unset: `/api` (Vite dev server proxies to the API).
# For a remote API or plain `vite preview`, set the full URL and add that origin to
# CLINICAL_DEID_CORS_ORIGINS on the server.
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Sent as `X-API-Key` on every request. Required when the API has
# CLINICAL_DEID_ADMIN_API_KEYS / CLINICAL_DEID_INFERENCE_API_KEYS configured.
# Use an **admin**-scoped key for the Playground.
# VITE_API_KEY=
